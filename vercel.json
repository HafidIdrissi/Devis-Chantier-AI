{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "functions": {
    "api/generate-devis.js": {
      "maxDuration": 20
    }
  },
  "rewrites": [
    {
      "source": "/api/generate-devis",
      "destination": "/api/generate-devis"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
